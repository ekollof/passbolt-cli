# You can also set PASSBOLT_CONFIG to point at this file instead of using -c.

[passbolt]
# The URL of your Passbolt server
server_url = https://passbolt.example.com

# Your Passbolt username (email address)
username = user@example.com

# Path to your GPG private key file
# This is the same key used for account recovery in the browser
private_key_path = ~/.passbolt/private_key.asc

# Your GPG key fingerprint (optional)
# user_fingerprint = ABCDEF1234567890

# Your Passbolt user UUID (optional for GPG auth, required for JWT auth)
# Find it in the Passbolt web UI under Profile, or leave unset to auto-fetch via /users/me.json
# user_id = 8bb80df5-700c-48ce-b568-85a60fc3c8f2

# Authentication method: auto (default), gpg, or jwt
# auto tries GPGAuth first, then falls back to JWT when GPG fails
# auth_method = auto

# Verify the Passbolt server identity before login (GPGAuth stage 0)
# verify_server = false

# MFA TOTP secret for non-interactive MFA (base32, same as your authenticator app)
# mfa_totp_secret =

# Passphrase for your GPG private key (optional, will prompt if not provided)
# Leave empty or comment out for better security
# passphrase = your_gpg_passphrase

# You can also execute a command to retrieve the passphrase securely:
# passphrase = exec:pass show passbolt/gpg-passphrase
# passphrase = exec:secret-tool lookup passbolt passphrase
# passphrase = exec:gpg --decrypt ~/.passbolt/passphrase.gpg

# Clipboard timeout in seconds (default: 45)
# The password will be automatically cleared from the clipboard after this time
# Set to 0 to disable automatic clearing
# clipboard_timeout = 45
